# 네이버 검색광고 API (https://manage.searchad.naver.com > 도구 > API 사용 관리)
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# 네이버 오픈API - 블로그 검색 (https://developers.naver.com/apps)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Instagram Graph API (Meta for Developers, 비즈니스/크리에이터 계정 필요)
IG_ACCESS_TOKEN=
IG_USER_ID=

# YouTube Data API v3 (Google Cloud Console > API 및 서비스 > 사용자 인증 정보)
YOUTUBE_API_KEY=

# 텔레그램 봇 (일일 리포트 + 챗봇) — @BotFather로 봇 생성, @userinfobot으로 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 웹훅 검증용 임의 문자열 (Vercel에만 등록, setWebhook secret_token과 동일하게)
TELEGRAM_WEBHOOK_SECRET=
